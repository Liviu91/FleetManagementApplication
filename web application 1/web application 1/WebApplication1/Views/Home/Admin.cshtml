@model IEnumerable<WebApplication1.DTOs.DisplayDTO>

@{
    ViewData["Title"] = "Fleet Management Dashboard";
}

<div class="container-fluid mt-4">
    <h1 class="mb-4">Fleet Management Dashboard</h1>
    
    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button">
                <i class="bi bi-speedometer2"></i> Overview
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="drivers-tab" data-bs-toggle="tab" data-bs-target="#drivers" type="button">
                <i class="bi bi-people"></i> Drivers
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="vehicles-tab" data-bs-toggle="tab" data-bs-target="#vehicles" type="button">
                <i class="bi bi-truck"></i> Vehicles
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="routes-tab" data-bs-toggle="tab" data-bs-target="#routes" type="button">
                <i class="bi bi-map"></i> Routes
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="monitoring-tab" data-bs-toggle="tab" data-bs-target="#monitoring" type="button">
                <i class="bi bi-activity"></i> Live Monitoring
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="adminTabsContent">
        
        <!-- Overview Tab -->
        <div class="tab-pane fade show active" id="overview" role="tabpanel">
            <div class="row mt-4">
                <div class="col-md-3">
                    <div class="card text-white bg-primary mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Total Drivers</h5>
                            <h2 id="totalDrivers">0</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-white bg-success mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Total Vehicles</h5>
                            <h2 id="totalVehicles">0</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-white bg-warning mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Active Routes</h5>
                            <h2 id="activeRoutes">0</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-white bg-info mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Total Routes</h5>
                            <h2 id="totalRoutes">0</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-12">
                    <h4>Recent Activity</h4>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Driver</th>
                                <th>Vehicle</th>
                                <th>Route</th>
                                <th>Status</th>
                                <th>Start Date</th>
                            </tr>
                        </thead>
                        <tbody id="recentActivityTable">
                            <!-- Populated by JavaScript -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Drivers Tab -->
        <div class="tab-pane fade" id="drivers" role="tabpanel">
            <div class="mt-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>Driver Management</h3>
                    <button class="btn btn-primary" onclick="showAddUserModal()">
                        <i class="bi bi-plus-circle"></i> Add Driver
                    </button>
                </div>
                <table class="table table-bordered table-hover" id="driversTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 50px;"></th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Total Routes</th>
                            <th>Active Routes</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Vehicles Tab -->
        <div class="tab-pane fade" id="vehicles" role="tabpanel">
            <div class="mt-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>Vehicle Management</h3>
                    <button class="btn btn-success" onclick="showAddCarModal()">
                        <i class="bi bi-plus-circle"></i> Add Vehicle
                    </button>
                </div>
                <table class="table table-bordered table-hover" id="carsTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 50px;"></th>
                            <th>Serial Number</th>
                            <th>Total Routes</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Routes Tab -->
        <div class="tab-pane fade" id="routes" role="tabpanel">
            <div class="mt-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>Route Management</h3>
                    <button class="btn btn-info" onclick="showAddRouteModal()">
                        <i class="bi bi-plus-circle"></i> Create Route
                    </button>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label>Filter by Status:</label>
                        <select class="form-select" id="statusFilter" onchange="filterRoutes()">
                            <option value="">All</option>
                            <option value="Assigned">Assigned</option>
                            <option value="Started">Started</option>
                            <option value="Finished">Finished</option>
                        </select>
                    </div>
                </div>

                <table class="table table-bordered table-hover" id="routesTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 50px;"></th>
                            <th>Route Name</th>
                            <th>Start Location</th>
                            <th>End Location</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="routesTableBody">
                        <!-- Populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Live Monitoring Tab -->
        <div class="tab-pane fade" id="monitoring" role="tabpanel">
            <div class="mt-4">
                <h3>Real-Time Vehicle Monitoring</h3>
                <p class="text-muted">Monitor active vehicles with live telemetry data</p>
                
                <div id="activeVehiclesGrid" class="row">
                    <!-- Populated by JavaScript with active vehicle cards -->
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .bd-bar > .btn, .bd-bar > .btn-group {
        margin: .25rem .125rem;
    }
    
    .expand-btn {
        padding: 0;
        border: none;
        background: none;
        color: #0d6efd;
        cursor: pointer;
        transition: transform 0.2s;
    }
    
    .expand-btn:hover {
        color: #0a58ca;
    }
    
    .driver-details-row, .car-details-row, .route-details-row {
        background-color: #f8f9fa;
    }
    
    .driver-row:hover, .car-row:hover, .route-row:hover {
        background-color: #f8f9fa;
        cursor: pointer;
    }
    
    .route-map-container {
        height: 400px;
        width: 100%;
        border-radius: 8px;
        border: 1px solid #dee2e6;
    }
    
    .telemetry-panel {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 15px;
        margin-top: 10px;
    }
    
    .telemetry-panel h6 {
        margin-bottom: 10px;
        color: #495057;
    }
    
    .telemetry-value {
        font-size: 1.4rem;
        font-weight: 600;
    }
    
    .telemetry-label {
        font-size: 0.8rem;
        color: #6c757d;
    }
</style>

@section Scripts {
<script src="~/js/admin.js" asp-append-version="true"></script>
}
